# Copy to managed-credentials.yaml (untracked) and keep this file as your
# inventory of credentials managed by this bootstrap.

credentials:
  - env: VAULT_ADDR
    source: HCP Vault Ezra.VAULT_ADDR
    category: vault-mcp
    required: true
    rotation: on-cluster-change

  - env: VAULT_TOKEN
    source: HCP Vault Ezra.VAULT_TOKEN
    category: vault-mcp
    required: true
    rotation: ttl

  - env: VAULT_NAMESPACE
    source: HCP Vault Ezra.VAULT_NAMESPACE
    category: vault-mcp
    required: false
    default: admin

  - env: HCP_PROJECT_ID
    source: HCP Vault Ezra.HCP_PROJECT_ID
    category: metadata
    required: false

  - env: HCP_VAULT_CLUSTER_ID
    source: HCP Vault Ezra.HCP_VAULT_CLUSTER_ID
    category: metadata
    required: false

  - env: VAULT_SYNC_ROLE_ID
    source: Vault K8s Creds.VAULT_SYNC_ROLE_ID
    category: vault-k8s
    required: true
    rotation: on-role-rekey

  - env: VAULT_SYNC_SECRET_ID
    source: Vault K8s Creds.VAULT_SYNC_SECRET_ID
    category: vault-k8s
    required: true
    rotation: ttl

  - env: VAULT_AUTH_MOUNT
    source: Vault K8s Creds.VAULT_AUTH_MOUNT
    category: vault-k8s
    required: true

  - env: VAULT_KV_MOUNT
    source: Vault K8s Creds.VAULT_KV_MOUNT
    category: vault-k8s
    required: true

  - env: VAULT_ESO_ROLE
    source: Vault K8s Creds.VAULT_ESO_ROLE
    category: vault-k8s
    required: true

  - env: GITHUB_TOKEN
    source: Vault path mcp-kv/data/github/runner-bootstrap field GITHUB_TOKEN
    category: github-runner
    required: true
    rotation: manual-or-gh-token-rotation

  - env: OCI_USER_OCID
    source: Vault path mcp-kv/data/oci/terraform-runner field OCI_USER_OCID
    category: oci-runner
    required: true

  - env: OCI_TENANCY_OCID
    source: Vault path mcp-kv/data/oci/terraform-runner field OCI_TENANCY_OCID
    category: oci-runner
    required: true

  - env: OCI_FINGERPRINT
    source: Vault path mcp-kv/data/oci/terraform-runner field OCI_FINGERPRINT
    category: oci-runner
    required: true

  - env: OCI_REGION
    source: Vault path mcp-kv/data/oci/terraform-runner field OCI_REGION
    category: oci-runner
    required: true

  - env: OCI_PRIVATE_KEY
    source: Vault path mcp-kv/data/oci/terraform-runner field OCI_PRIVATE_KEY
    category: oci-runner
    required: true
    rotation: on-key-roll

  - env: OCI_PUBLIC_KEY
    source: Vault path mcp-kv/data/oci/terraform-runner field OCI_PUBLIC_KEY
    category: oci-runner
    required: false
